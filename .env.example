# ── 사이트 기본 설정 ──────────────────────────────────────────────────────────
# 배포 후 실제 도메인으로 변경하세요 (예: https://mysite.com)
NEXT_PUBLIC_SITE_URL=https://your-domain.com
NEXT_PUBLIC_SITE_NAME=My Project

# ── SEO: 구글 서치콘솔 ────────────────────────────────────────────────────────
# 1. https://search.google.com/search-console 접속
# 2. URL 접두어로 사이트 등록
# 3. '다른 확인 방법' > 'HTML 태그' 클릭
# 4. content="XXXX" 안의 값만 복사해서 아래에 붙여넣기
GOOGLE_SITE_VERIFICATION=

# ── SEO: 네이버 서치어드바이저 ──────────────────────────────────────────────
# 1. https://searchadvisor.naver.com 접속
# 2. 웹마스터 도구 > 사이트 등록
# 3. 'HTML 태그' 방식으로 인증
# 4. content="XXXX" 안의 값만 복사해서 아래에 붙여넣기
NAVER_SITE_VERIFICATION=

# ── 구글 애널리틱스 (선택) ────────────────────────────────────────────────────
# 1. https://analytics.google.com 에서 GA4 속성 생성
# 2. 측정 ID (G-XXXXXXXXXX 형식) 복사해서 아래에 붙여넣기
NEXT_PUBLIC_GA_ID=
